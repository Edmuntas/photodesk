# ── xAI Grok API key (required for AI photo processing) ──────────────────────
XAI_API_KEY=xai-...

# ── Server port (default: 3001) ───────────────────────────────────────────────
PORT=3001

# ── Override data directories (optional) ─────────────────────────────────────
# Defaults to data/results/ and data/uploads/ in repo root
# RESULTS_DIR=/absolute/path/to/results
# UPLOADS_DIR=/absolute/path/to/uploads

# ── To keep accessing previous sessions from ai photo decltter/ ───────────────
# RESULTS_DIR=/Users/edmontmac16max/ai photo decltter/results

# ── Sentry error monitoring (optional) ───────────────────────────────────────
# Backend DSN (secret — server-side only, not exposed to browser)
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Frontend DSN (public — returned via /api/config to browser SDK)
# SENTRY_DSN_PUBLIC=https://xxx@oXXX.ingest.sentry.io/XXX
# Note: use separate Sentry projects for backend and frontend, or the same DSN for both
