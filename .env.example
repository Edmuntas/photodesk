# ── xAI Grok API key (required for AI photo processing) ──────────────────────
XAI_API_KEY=xai-...

# ── Server port (default: 3001) ───────────────────────────────────────────────
PORT=3001

# ── Override data directories (optional) ─────────────────────────────────────
# Defaults to data/results/ and data/uploads/ in repo root
# RESULTS_DIR=/absolute/path/to/results
# UPLOADS_DIR=/absolute/path/to/uploads

# ── To keep accessing previous sessions from ai photo decltter/ ───────────────
# RESULTS_DIR=/Users/edmontmac16max/ai photo decltter/results
